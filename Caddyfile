# Caddyfile — SSL automatique via Let's Encrypt
# {$DOMAIN} est injecté depuis la variable d'environnement DOMAIN

# Frontend
app.{$DOMAIN} {
    # Les routes OAuth sont sur l'API (flow navigateur initié depuis app.domain)
    handle /api/oauth/* {
        reverse_proxy api:3001
    }
    reverse_proxy web:3000
}

# API
api.{$DOMAIN} {
    reverse_proxy api:3001
}
