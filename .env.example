# PostgreSQL
DATABASE_URL=postgresql://aarfang:aarfang@localhost:5432/aarfang

# Redis
REDIS_URL=redis://localhost:6379

# JWT — générer avec : openssl rand -base64 64
JWT_SECRET=change_me_in_production

# Chiffrement credentials intégrations — 32 octets hex : openssl rand -hex 32
ENCRYPTION_KEY=change_me_32_bytes_hex_in_production

# API
API_PORT=3001
API_HOST=0.0.0.0

# URL publique de l'application web — utilisée dans les alertes email et pour CORS
APP_URL=http://localhost:5173
# URL publique de l'API — utilisée pour les redirect URI OAuth
API_URL=http://localhost:3001

# Les credentials Google OAuth (client_id, client_secret) sont configurés
# par organisation dans Paramètres → Intégrations → Google Search Console

# CORS — origines autorisées (séparées par virgule)
# En production : https://app.yourdomain.com
# En dev : laisser vide (localhost:5173 et localhost:4173 sont inclus par défaut)
CORS_ORIGINS=

# Email — alertes de dégradation (optionnel)
# Compatible avec tout serveur SMTP (Mailpit en local, Postmark, Brevo, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@aarfang.com

# Les clés API tierces (PageSpeed, Semrush, Claude, OpenAI, etc.)
# sont gérées par organisation dans l'interface → Paramètres → Intégrations

# ── Variables spécifiques au déploiement OVH VPS (docker-compose.ovh.yml) ────
# Copier ce bloc dans .env sur le serveur et remplir les valeurs :
#
# DOMAIN=yourdomain.com
# APP_URL=https://app.yourdomain.com
# API_URL=https://api.yourdomain.com
# DB_USER=aarfang
# DB_PASSWORD=            ← openssl rand -hex 32  ⚠ hex uniquement — base64 contient des / + = qui cassent l'URL
# DB_NAME=aarfang
# JWT_SECRET=             ← openssl rand -base64 64
# ENCRYPTION_KEY=         ← openssl rand -hex 32
# CORS_ORIGINS=https://app.yourdomain.com
